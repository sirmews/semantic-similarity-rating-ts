{
  "name": "@sirmews/semantic-similarity-rating",
  "version": "1.0.0",
  "description": "TypeScript port of the Semantic-Similarity Rating (SSR) methodology for converting LLM responses to Likert-scale probability distributions",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib/**/*",
    "!lib/**/__tests__/**"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "jest",
    "changelog": "changelogen --output CHANGELOG.md"
  },
  "keywords": [
    "semantic-similarity",
    "llm",
    "likert",
    "embeddings",
    "nlp",
    "typescript",
    "ssr"
  ],
  "author": "pymc-labs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sirmews/semantic-similarity-rating-ts.git"
  },
  "homepage": "https://github.com/sirmews/semantic-similarity-rating-ts",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "changelogen": "^0.6.2",
    "jest": "^30.0.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  }
}
